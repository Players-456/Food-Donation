# ============================================================
#  Smart Food Donation System — Environment Variables
#  Copy this file to .env and fill in the actual values
#  ⚠️  NEVER push .env to GitHub!
# ============================================================

# ── Server Configuration ────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas Connection ────────────────────────────────
# Get your MongoDB Atlas URI from https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/foodDonationDB

# ── JWT Secret (Generate a strong random string) ────────────
# Use this command to generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_to_strong_random_value

# ── Email Service (Gmail with App Password) ────────────────
# Instructions:
# 1. Enable 2FA on your Gmail account
# 2. Generate App Password at https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password here (remove spaces)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_character_app_password

# ── Render Production URL (for CORS whitelist) ──────────────
# Example: https://food-donation-xxx.onrender.com
RENDER_URL=your_render_backend_url

# ── Vercel Frontend URL (for CORS) ──────────────────────────
# Example: https://food-donation-client.vercel.app
FRONTEND_URL=your_vercel_frontend_url
