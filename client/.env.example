# ============================================================
#  Smart Food Donation Client — Environment Variables
#  Copy this file to .env.local and fill in the actual values
#  Note: React environment variables must start with REACT_APP_
# ============================================================

# ── Backend API Configuration ───────────────────────────────
# Development: http://localhost:5000
# Production (Render): https://your-render-backend.onrender.com
REACT_APP_API_BASE_URL=http://localhost:5000/api

# ── Environment ─────────────────────────────────────────────
# Values: development, production, staging
REACT_APP_ENV=development

# ── Optional: Analytics, Error Tracking, etc. ───────────────
# REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id
# REACT_APP_SENTRY_DSN=your_sentry_dsn
